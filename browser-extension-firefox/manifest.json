{
  "manifest_version": 3,
  "name": "PIDM Download Helper",
  "version": "1.0.1",
  "description": "Capture download links and send them to PIDM — supports YouTube, videos, audio, files and more.",
  "browser_specific_settings": {
    "gecko": {
      "id": "pidm@rincol.tech",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "webRequest",
    "tabs",
    "storage",
    "activeTab",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PIDM Download Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
